{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UltrastarDJ",
  "version": "0.1.0",
  "identifier": "com.retokupfer.ultrastardj",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UltrastarDJ",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$HOME/**", "$DESKTOP/**", "$DOCUMENT/**", "$DOWNLOAD/**", "$AUDIO/**", "$VIDEO/**", "$PICTURE/**", "$PUBLIC/**", "$RUNTIME/**", "$TEMP/**", "$APPCONFIG/**", "$APPDATA/**", "$APPLOCALDATA/**", "$APPCACHE/**", "$APPLOG/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
