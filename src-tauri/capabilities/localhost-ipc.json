{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "localhost-ipc",
  "description": "Grants all IPC permissions to the app when served from http://localhost (tauri-plugin-localhost production mode)",
  "remote": {
    "urls": ["http://localhost:*"]
  },
  "local": false,
  "windows": ["main", "beamer", "beamer2"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "store:allow-load",
    "store:allow-set",
    "store:allow-get",
    "store:allow-save",
    "store:allow-clear",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "/Volumes/**" }
      ]
    }
  ]
}
