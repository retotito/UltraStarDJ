{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "beamer", "beamer2"],
  "permissions": [
    "allow-app-commands",
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "store:allow-load",
    "store:allow-set",
    "store:allow-get",
    "store:allow-save",
    "store:allow-clear",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "/Volumes/**" }
      ]
    }
  ]
}
